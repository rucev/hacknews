{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2019",
    "outDir": "build",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "lib": [
      "ES6",
      "DOM"
    ],
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "tests/**/*.test.ts",
    "vitest.config.js"
  ],
}